# Default-deny: ignore everything first.
*

# Allow directory traversal for re-includes.
!*/

# Root files to keep tracked.
!.gitignore
!AGENTS.md
!README.md
!Makefile
!main.py
!pyproject.toml
!config.yaml
!.pre-commit-config.yaml

# Source and test trees.
!api/
!api/**
!domain/
!domain/**
!ingestion/
!ingestion/**
!sources/
!sources/**
!tests/
!tests/**
!docs/
!docs/assets/
!docs/assets/gold_profile_btc_1m_example.png

# Explicitly ignore local-only runtime/build/cache artifacts.
.venv/
.vscode/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.logs/
.ipynb_checkpoints/
*.pyc
*.egg-info/
lake/
plots/
exports/
.run/
lake_test/
.env
.env.*
docker/.env
